# ── Analysis engine (required) ────────────────────────────────
# Claude API key from https://console.anthropic.com  (or use `ant auth login`)
ANTHROPIC_API_KEY=
# Model tier. Launch default = Sonnet 5 (near-Opus quality, ~5x cheaper).
# Switch to claude-haiku-4-5 (cheapest) or claude-opus-4-8 (max quality).
MODEL=claude-sonnet-5

# ── Server ────────────────────────────────────────────────────
PORT=8080

# ── Abuse protection ──────────────────────────────────────────
# Rolling window (ms) + caps. Global cap bounds total Claude spend in open mode.
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=20
RATE_LIMIT_GLOBAL_MAX=100
# Input size caps (characters). imageBase64 ~8M chars ≈ 6 MB image.
MAX_TEXT_CHARS=12000
MAX_IMAGE_CHARS=8000000
# Hard timeout on the Claude call (ms).
ANALYZE_TIMEOUT_MS=45000

# ── x402 payment (A2MCP) via the OKX Payment SDK ──────────────
# Settlement is USDT0 on X Layer (eip155:196), gasless via EIP-3009.
# The wallet that receives payments = your OKX Agentic Wallet address.
PAY_TO_ADDRESS=
# Per-call price the SDK understands: "$0.02" (USD, auto-converted) or a decimal.
PRICE=$0.02
# How long a payment challenge stays valid.
MAX_TIMEOUT_SECONDS=300
# OKX facilitator base URL. Leave blank to use the SDK default (https://web3.okx.com).
OKX_BASE_URL=
# Set "true" to enforce x402; "false" runs the endpoint open (dev/demo).
PAYMENTS_ENABLED=false

# ── OKX API credentials (facilitator auth + OnchainOS enrichment) ──
# From the OKX Developer Portal (web3.okx.com/onchain-os/dev-portal).
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
